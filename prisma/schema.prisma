generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Item {
  id            Int       @id @default(autoincrement())
  sourceType    String    @map("source_type")
  externalId    String    @map("external_id")
  title         String
  url           String
  author        String?
  description   String?
  publishedAt   DateTime  @map("published_at")
  firstSeenAt   DateTime  @default(now()) @map("first_seen_at")
  lastUpdatedAt DateTime  @updatedAt @map("last_updated_at")

  // Current engagement metrics
  score        Int @default(0)
  commentCount Int @default(0) @map("comment_count")

  // AI relevance
  matchedKeywords String[] @map("matched_keywords")
  isRelevant      Boolean  @default(true) @map("is_relevant")

  // Virality
  viralityScore Float   @default(0) @map("virality_score")
  isViral       Boolean @default(false) @map("is_viral")
  velocity      Float   @default(0)
  acceleration  Float   @default(0)

  // Platform-specific metadata (stored as JSON)
  metadata Json?

  // Relations
  snapshots    EngagementSnapshot[]
  alerts       Alert[]
  tickerImpacts TickerImpact[]

  @@unique([sourceType, externalId])
  @@index([isViral, viralityScore])
  @@index([sourceType])
  @@index([publishedAt])
  @@map("items")
}

model EngagementSnapshot {
  id          Int      @id @default(autoincrement())
  itemId      Int      @map("item_id")
  score       Int
  commentCount Int     @map("comment_count")
  recordedAt  DateTime @default(now()) @map("recorded_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, recordedAt])
  @@map("engagement_snapshots")
}

model Alert {
  id        Int      @id @default(autoincrement())
  itemId    Int      @map("item_id")
  type      String   // "velocity_spike", "absolute_threshold", "cross_platform"
  message   String
  score     Float
  createdAt DateTime @default(now()) @map("created_at")
  read      Boolean  @default(false)

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([read])
  @@map("alerts")
}

model TickerImpact {
  id        Int      @id @default(autoincrement())
  itemId    Int      @map("item_id")
  ticker    String   // e.g. "NVDA", "MSFT"
  name      String   // e.g. "NVIDIA", "Microsoft"
  sentiment String   // "bullish", "bearish", "neutral"
  confidence Float   @default(0.5) // 0-1 confidence score
  source    String   @default("keyword") // "keyword", "llm", "manual"
  createdAt DateTime @default(now()) @map("created_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, ticker])
  @@index([ticker])
  @@index([ticker, sentiment])
  @@map("ticker_impacts")
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String?
  createdAt    DateTime  @default(now()) @map("created_at")

  sessions Session[]
  keywords UserKeyword[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    Int      @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model UserKeyword {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  keyword   String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, keyword])
  @@index([userId])
  @@map("user_keywords")
}

model DynamicKeyword {
  id          Int      @id @default(autoincrement())
  keyword     String   @unique
  status      String   @default("candidate") // candidate | active | retired
  score       Float    @default(0)            // trending strength 0-1
  hitCount    Int      @default(0) @map("hit_count")
  missCount   Int      @default(0) @map("miss_count")
  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("dynamic_keywords")
}

model DailySnapshot {
  id        Int      @id @default(autoincrement())
  date      String   @unique // "2026-03-12" format, ET timezone
  items     Json     // Full serialized item array (same shape as API response)
  itemCount Int      @map("item_count")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([date])
  @@map("daily_snapshots")
}
