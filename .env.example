# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/trending?schema=public"

# Optional: GitHub API token for higher rate limits (5K/hr vs 60/hr)
# Get one at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Optional: Reddit API credentials (for higher rate limits)
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional: Benzinga API key for headlines (free tier via AWS Marketplace)
# https://aws.amazon.com/marketplace/pp/prodview-xwgvhwowjmw3g
BENZINGA_API_KEY=
